# Clerk：Dashboard → API Keys，Next.js 專案要用 NEXT_PUBLIC_ 前綴（不是 Vite 的 VITE_ 前綴）
# 複製這個檔案成 .env.local（已被 .gitignore 的 *.local 規則排除），不要直接改這個檔案
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Postgres：Project Settings → Database
# DATABASE_URL 用連線池（Transaction pooler，6543 埠）給執行期查詢用
# DIRECT_URL 用直連（5432 埠）給 `prisma migrate` 用
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:xxxxxxxx@aws-0-xxxxxxxx.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxxxxxxxxxx:xxxxxxxx@aws-0-xxxxxxxx.pooler.supabase.com:5432/postgres
